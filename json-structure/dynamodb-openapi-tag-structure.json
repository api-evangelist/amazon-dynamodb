  "name": "Tag",
  "description": "Tag schema from Amazon DynamoDB API",
  "type": "object",
  "properties": {
    "Key": {
      "type": "string",
      "description": "The key of the tag",
      "minLength": 1,
      "maxLength": 128
    },
    "Value": {
      "type": "string",
      "description": "The value of the tag",
