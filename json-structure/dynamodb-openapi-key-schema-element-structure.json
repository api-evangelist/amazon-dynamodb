{
  "$schema": "https://json-structure.org/meta/core/v0/#",
  "$id": "https://raw.githubusercontent.com/api-evangelist/amazon-dynamodb/refs/heads/main/json-structure/dynamodb-openapi-key-schema-element-structure.json",
  "name": "KeySchemaElement",
  "description": "Represents a single element of a key schema",
  "type": "object",
  "properties": {
    "AttributeName": {
      "type": "string",
      "description": "The name of a key attribute"
    },
    "KeyType": {
      "type": "string",
      "description": "The role that this key attribute will assume",
      "enum": [
        "HASH",
        "RANGE"
      ]
    }
  },
  "required": [
    "AttributeName",
    "KeyType"
  ]
}